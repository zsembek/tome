# ─────────── Tome .env ───────────
# Postgres (pgvector + ltree required for full functionality)
# IMPORTANT: change the password for production (it is also passed to the
#            bundled postgres container).
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/tome
POSTGRES_PASSWORD=postgres           # password for the bundled postgres container
TOME_SCHEMA=tome

# ─── LLM (any provider) ───
LLM_PROVIDER=openai                  # openai|azure_openai|anthropic|xai|ollama|vllm
LLM_STRUCTURE_MODEL=gpt-4o
LLM_VISION_MODEL=gpt-4o
LLM_NAMING_MODEL=gpt-4o-mini
LLM_ATLAS_MODEL=gpt-4o
LLM_MAX_COMPLETION_TOKENS=16000
LLM_TIMEOUT=60                       # per-request seconds; a hung model never freezes ingestion
LLM_MAX_RETRIES=2                    # bounded retries with capped backoff (SDK retries disabled)
OPENAI_API_KEY=
# OPENAI_BASE_URL=                   # for xai/ollama/vllm/compatible endpoints
# ANTHROPIC_API_KEY=

# ─── Azure OpenAI (uncomment this block instead of the OpenAI one above) ───
# IMPORTANT: LLM_*_MODEL = the Azure DEPLOYMENT name (not "gpt-4o"!). If you have
#            a single deployment, use its name for all four. gpt-5.x / o-series
#            (reasoning) work: the adapter sends max_completion_tokens and omits
#            temperature automatically.
# LLM_PROVIDER=azure_openai
# LLM_STRUCTURE_MODEL=<deployment-name>
# LLM_VISION_MODEL=<deployment-name>        # deployment must be multimodal
# LLM_NAMING_MODEL=<deployment-name>
# LLM_ATLAS_MODEL=<deployment-name>
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_KEY=<key>
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ─── Embedder (hybrid search) ───
EMBED_ENABLED=true
EMBED_PROVIDER=openai                # openai|azure_openai|local|fastembed|hash|voyage|cohere
EMBED_MODEL=text-embedding-3-small   # for azure_openai: the embeddings DEPLOYMENT name
# No embeddings deployment on Azure? → EMBED_ENABLED=false (search falls back to BM25)
# Offline options: fastembed (light ONNX; the local image bakes it in via TOME_EXTRAS)
# or hash (deterministic, zero-download lexical semantics).

# ─── Agent memory (Markdown-native long-term memory for agents) ───
MEMORY_ENABLED=true
MEMORY_SCOPE=shared                  # shared = workspace-wide | isolated = private per agent_id
MEMORY_DEFAULT_AGENT=default         # agent_id used when X-Agent-Id is absent
MEMORY_REDACT=true                   # redact secrets before storing memory (recommended)
MEMORY_DECAY_HALF_LIFE_DAYS=30       # importance half-life for decay/GC
MEMORY_WORKING_CAP=500               # max working-tier notes per agent before GC trims
MEMORY_MIN_IMPORTANCE=0.05           # decayed memories below this are evicted by `tome memory-gc`

# ─── Extraction (pluggable) ───
EXTRACT_PRIMARY=tika                 # tika|azure_di|vision_llm|passthrough
EXTRACT_SCANNED=                     # for scanned docs (e.g. azure_di), optional
EXTRACT_FALLBACK=vision_llm          # backfills "poor" pages
EXTRACT_OCR_LANG=eng+rus             # starting OCR languages (auto-corrected below)
EXTRACT_AUTO_LANG=true               # AI detects the real language(s) and re-scans OCR accordingly
STRUCTURE_ENABLED=true               # false = keep extracted text as-is (no LLM restructuring cost)
INGEST_REDACT=false                  # true = redact secrets/PII from documents during ingestion
TIKA_URL=http://tika:9998
# AZURE_DI_ENDPOINT=  AZURE_DI_KEY=

# ─── Object store (originals, figures, version snapshots) ───
# Default backend = local filesystem. Files are written under the `_store/`
# directory (gitignored) — in Docker that is the named volume /app/_store, NOT
# your repo. Set STORAGE_DIR to put the data anywhere you like (e.g. /var/lib/tome),
# or switch to MinIO/S3 (S3_USE=true) for production.
STORAGE_DIR=                         # empty → <package>/_store ; or an absolute path
S3_USE=false                         # true → store originals/figures in MinIO/S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tome

# ─── Limits / thresholds (all configurable) ───
TARGET_LANG=auto
STRUCTURE_SMART=true
FAITHFULNESS_MIN=0.85

# ─── Ingestion speed ───
PAGE_CONCURRENCY=4                   # process this many pages in parallel (structure+verify+vision)
                                     #   biggest speedup for multi-page docs; keep <= DB pool (8) and LLM RPM
VISION_ENABLED=true                  # false = skip figure description (text-only, much faster/cheaper)
STRUCTURE_ESCALATE=true              # false = single LLM pass per page (no 2nd-pass on faithfulness miss)
MAX_MD_CHARS=100000
MAX_SECTION_CHARS=8000
MIN_SECTION_CHARS=40
CHUNK_TOKENS=512
CHUNK_OVERLAP=64
WORKER_CONCURRENCY=2
PIPELINE_VERSION=v1

# ─── Access / Identity (secure-by-default) ───
# Sign-in is required by default. First run: create an admin via the UI
# ("Create the first administrator" screen) or POST /v1/auth/bootstrap,
# or seed it from env (TOME_ADMIN_EMAIL / TOME_ADMIN_PASSWORD below).
TOME_OPEN=false                      # true = OPEN mode with no auth (localhost only!)
TOME_SECRET=                         # REQUIRED (≥32 chars): signs image asset URLs
SESSION_TTL_HOURS=168                # session lifetime (7 days)
# TOME_ADMIN_EMAIL=admin@example.com  # auto-seed the first admin on first start
# TOME_ADMIN_PASSWORD=                 # (≥8 chars; set both or neither)
TOME_API_KEY=                        # optional service master key (integrations/CI)
# MCPO_API_KEY=                        # key for the HTTP MCP (8765). FAIL-CLOSED: without it
#                                      #   (and without TOME_OPEN) the MCP binds to localhost only.
RUN_INPROCESS_WORKER=true            # false if you run a separate worker container
# Crash/restart recovery: a worker touches its running job every JOB_HEARTBEAT_SECONDS;
# a job whose heartbeat is older than JOB_LEASE_SECONDS is treated as orphaned (its worker
# was killed by a rebuild/restart), requeued, and resumed from its last per-page checkpoint.
# Keep the lease comfortably above the heartbeat (and above your worst-case single-page time).
JOB_LEASE_SECONDS=90
JOB_HEARTBEAT_SECONDS=15

# ─── Hardening ───
TOME_STRICT=false                    # true = refuse to start on insecure config (default creds / empty secret)
RATE_LIMIT_PER_MIN=120               # per-client API rate limit (0 = disabled); in-process per worker
RATE_LIMIT_BURST=0                   # burst capacity (0 = equals RATE_LIMIT_PER_MIN)
MAX_UPLOAD_MB=200                    # reject uploads larger than this (413)
WEBHOOK_ALLOW_HOSTS=                 # optional comma-separated host allowlist for webhook delivery
#                                    #   (delivery is HMAC-signed; private/loopback/metadata IPs are always blocked)
